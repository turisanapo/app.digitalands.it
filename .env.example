# ── Frontend (Vite — baked into the bundle at build time) ──────────────
# Local stack values are printed by `supabase start` / `supabase status`.
# For production, use the project's URL and anon key from the Supabase dashboard.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Used for auth email redirects (frontend) and Stripe success/cancel URLs (api).
# Falls back to window.location.origin / the vercel.app URL if unset.
VITE_SITE_URL=http://localhost:5173

# ── Serverless functions in api/ (server-side only — NEVER expose to the client) ──
# Not needed for `npm run dev`; required for `vercel dev` and the Vercel project settings.

# Same Supabase project as above. Service role key bypasses RLS:
# local one is printed by `supabase status`; production one is in Dashboard → Settings → API.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys).
STRIPE_SECRET_KEY=sk_test_...
# From the Stripe dashboard webhook config, or printed by
# `stripe listen --forward-to localhost:3000/api/webhook` for local testing.
STRIPE_WEBHOOK_SECRET=whsec_...
